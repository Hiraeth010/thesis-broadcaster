# The wallet whose swaps trigger a thesis draft. This is YOUR wallet.
WALLET_ADDRESS=

# Optional. Without a key the app uses a public RPC (rate-limited).
# Helius — https://dashboard.helius.dev
HELIUS_API_KEY=
# Public HTTPS URL Helius will POST to. Use a tunnel in dev, Railway URL in prod.
WEBHOOK_URL=
# Shared secret echoed back in the Authorization header. Set it when registering.
WEBHOOK_AUTH=

# Local dashboard
PORT=3031

# Discord — Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=

# Telegram — create a bot with @BotFather, then get the chat id for your channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# X — bring your own app from developer.x.com. Your keys, your quota.
# Leave blank to disable.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Appended to every broadcast. Your fomo referral link, or anything else.
REFERRAL_LINK=

# Custom Solana RPC. Overrides HELIUS_API_KEY if set.
RPC_URL=

# How often to check for new trades (seconds)
POLL_SECONDS=15
