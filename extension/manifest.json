{
  "manifest_version": 3,
  "name": "thesis broadcaster",
  "version": "0.4.2",
  "description": "Broadcast your Solana trades to your own Discord, Telegram and X. Write the thesis on fomo, it posts itself.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://fomo.family/*",
    "https://solana-rpc.publicnode.com/*",
    "https://mainnet.helius-rpc.com/*",
    "https://discord.com/*",
    "https://api.telegram.org/*",
    "https://api.twitter.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://fomo.family/*"
      ],
      "js": [
        "hook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://fomo.family/*"
      ],
      "js": [
        "relay.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "thesis broadcaster",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
