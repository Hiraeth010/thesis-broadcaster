{
  "manifest_version": 3,
  "name": "thesis broadcaster",
  "version": "0.3.0",
  "description": "When you post a thesis on fomo, broadcast it to your own Discord, Telegram and X.",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:3031/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://fomo.family/*"],
      "js": ["hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://fomo.family/*"],
      "js": ["relay.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": { "default_popup": "popup.html", "default_title": "thesis broadcaster" }
}
